# IOC BLOCKER PRO - CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# API Endpoint Configuration
API_KEY=BANK123
IOC_ENDPOINT=http://40.81.244.175:9000/share/partners/bank/iocs_high.json

# Fetch Intervals (in seconds)
FETCH_INTERVAL=3600        # IOC Fetcher runs every 60 minutes
BLOCKER_INTERVAL=30        # Blocker Daemon runs every 30 seconds

# File Locations
IOC_FILE=iocs.json
DNS_CACHE_FILE=dns_cache.json
ALLOWLIST_FILE=allowlist.json

# Log Files
FETCHER_LOG=logs/ioc_fetcher.log
BLOCKER_LOG=logs/ioc_blocker.log
DASHBOARD_LOG=logs/dashboard.log

# nftables Configuration
NFT_TABLE=iocblocker
NFT_SET=block_v4

# Dashboard Configuration
DASHBOARD_PORT=5000
DASHBOARD_HOST=0.0.0.0

